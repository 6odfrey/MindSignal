{
  "expo": {
    "name": "Mind Signal",
    "slug": "mind-signal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mindsignal.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Mind Signal uses notifications to send you daily mood reminders and important mental health alerts."
      }
    },
    "android": {
      "package": "com.mindsignal.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#5B2D8E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5B2D8E",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "mind-signal"
      }
    }
  }
}
